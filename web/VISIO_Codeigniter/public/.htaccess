# ============================================================
# VISIO — public/.htaccess
# Redireciona todas as requisições para o index.php do CI4,
# exceto arquivos e pastas que realmente existem (assets, imagens, etc.)
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Garante que o caminho base está correto quando o projeto está em subpasta
    # Exemplo: se acessar em localhost/visio/public/, descomentar a linha abaixo
    # e ajustar o caminho:
    # RewriteBase /visio/public/

    # Se o arquivo ou pasta realmente existe, serve diretamente (CSS, JS, imagens)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Caso contrário, envia para o index.php (roteador CI4)
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    # Se mod_rewrite não estiver ativo, mostra mensagem de erro
    # Ative no Apache: a2enmod rewrite  (ou no XAMPP: habilitar no httpd.conf)
    ErrorDocument 404 "O módulo mod_rewrite do Apache não está ativo. Ative-o para usar o CI4."
</IfModule>
